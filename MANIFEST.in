include .env.example
include CONTRIBUTING.md
include GOAL.md
include LICENSE
include README.md
include SECURITY.md
include requirements.lock
include requirements-build.lock
include requirements*.txt
include *.bat
include marketsentinel.png
recursive-include .github *.yml *.yaml
recursive-include assets *.ico *.png *.svg
