# NEVER commit real secrets.
# Copy this file to ".env" and fill in values if you want LIVE trading/copy-trading.

# Your wallet private key (EOA that controls/owns the Polymarket account or proxy)
PRIVATE_KEY=

# If you trade via a Polymarket proxy wallet (Magic/email login or browser wallet proxy),
# set FUNDER_ADDRESS to the proxy wallet that holds your USDC/positions.
FUNDER_ADDRESS=

# Signature type:
# 0 = EOA (default)
# 1 = Email/Magic
# 2 = Browser wallet proxy
SIGNATURE_TYPE=

# Reserved for future non-Polymarket adapters. These are examples of where
# credentials should live if/when those adapters are implemented.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
IBKR_ACCOUNT_ID=
MANIFOLD_API_KEY=
