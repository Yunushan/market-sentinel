# NEVER commit real secrets.
# Copy this file to ".env" and fill in values if you want LIVE trading/copy-trading.

# Your wallet private key (EOA that controls/owns the Polymarket account or proxy)
PRIVATE_KEY=

# If you trade via a Polymarket proxy wallet (Magic/email login or browser wallet proxy),
# set FUNDER_ADDRESS to the proxy wallet that holds your USDC/positions.
FUNDER_ADDRESS=

# Signature type:
# 0 = EOA (default)
# 1 = Email/Magic
# 2 = Browser wallet proxy
SIGNATURE_TYPE=

# Kalshi live trading is disabled by default. If you explicitly enable it,
# use either KALSHI_PRIVATE_KEY_PATH or KALSHI_PRIVATE_KEY_PEM.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PRIVATE_KEY_PEM=
KALSHI_PRIVATE_KEY_PASSWORD=

# Reserved for future non-implemented adapters. These are examples of where
# credentials should live if/when those adapters are implemented.
IBKR_ACCOUNT_ID=

# Manifold MANA betting is disabled by default and requires explicit opt-in.
MANIFOLD_API_KEY=
