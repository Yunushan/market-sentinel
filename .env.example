# NEVER commit real secrets.
# Copy this file to ".env" and fill in values if you want LIVE trading/copy-trading.

# Your wallet private key (EOA that controls/owns the Polymarket account or proxy)
PRIVATE_KEY=

# If you trade via a Polymarket proxy wallet (Magic/email login or browser wallet proxy),
# set FUNDER_ADDRESS to the proxy wallet that holds your USDC/positions.
FUNDER_ADDRESS=

# Signature type:
# 0 = EOA (default)
# 1 = Email/Magic
# 2 = Browser wallet proxy
SIGNATURE_TYPE=

# Kalshi live trading is disabled by default. If you explicitly enable it,
# use either KALSHI_PRIVATE_KEY_PATH or KALSHI_PRIVATE_KEY_PEM.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PRIVATE_KEY_PEM=
KALSHI_PRIVATE_KEY_PASSWORD=

# Reserved for future non-implemented adapters. These are examples of where
# credentials should live if/when those adapters are implemented.
IBKR_ACCOUNT_ID=

# Manifold MANA betting is disabled by default and requires explicit opt-in.
MANIFOLD_API_KEY=

# Metaculus API calls require token authentication.
METACULUS_API_TOKEN=

# Myriad public API calls can use an optional API key when required by the deployment.
MYRIAD_API_KEY=

# Opinion OpenAPI calls require an API key.
OPINION_API_KEY=

# Gemini authenticated order posting is disabled by default and requires explicit opt-in.
GEMINI_API_KEY=
GEMINI_API_SECRET=

# Predict.fun mainnet API calls require an API key.
PREDICT_FUN_API_KEY=

# XO Markets authenticated data and guarded live orders use HMAC credentials.
XO_API_KEY=
XO_API_SECRET=

# Betfair Exchange API calls require an application key and session token.
BETFAIR_APP_KEY=
BETFAIR_SESSION_TOKEN=

# Limitless live trading is disabled by default and requires explicit opt-in.
LIMITLESS_TOKEN_ID=
LIMITLESS_TOKEN_SECRET=
LIMITLESS_ON_BEHALF_OF=

# SX Bet WebSocket and live trading are disabled by default and require explicit opt-in.
SX_BET_API_KEY=
SX_BET_PRIVATE_KEY=
SX_BET_MAKER_ADDRESS=

# Azuro live order posting is disabled by default and expects user-signed order data.
AZURO_BETTOR_ADDRESS=
AZURO_AFFILIATE_ADDRESS=

# Legacy Web3 read-only adapters use configured public GraphQL/indexer endpoints.
AUGUR_SUBGRAPH_URL=
OMEN_SUBGRAPH_URL=
ZEITGEIST_INDEXER_URL=
