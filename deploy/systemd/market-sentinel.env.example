# Copy to /etc/market-sentinel/market-sentinel.env and keep mode 0600.
# The default systemd unit binds only to 127.0.0.1. Do not expose the app
# directly to the Internet; use the bundled Caddy example for TLS and access control.

# Optional for authenticated health checks or an explicitly remote API bind.
# Generate with: openssl rand -hex 32
MARKET_SENTINEL_API_TOKEN=

# Required when the Caddy browser UI is exposed. Use the exact public HTTPS
# origin after replacing the hostname in deploy/caddy/Caddyfile.example. Multiple
# trusted origins can be comma-separated; wildcards and paths are not accepted.
# MARKET_SENTINEL_ALLOWED_ORIGINS=https://analytics.example.com

# Market credentials belong in this root-owned, mode-0600 file or a dedicated
# secret manager. Never place real values in data/config.json or source control.
# POLYMARKET_PRIVATE_KEY=
# POLY_API_KEY=
